# Optional — only needed for the live worldwide mash counter.
# Get these from Firebase console → Project settings → Your apps → Web app.
# Copy this file to .env.local and fill in the values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=babymash-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=babymash-app
VITE_FIREBASE_STORAGE_BUCKET=babymash-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
